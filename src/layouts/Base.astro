---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Yips — Golf Stats Tracker',
  description = 'Track it. Face it. Suck less. A golf stats app focused on strokes gained — the methodology that actually explains your game.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://theyips.app" />
  </head>
  <body>
    <slot />
  </body>
</html>
