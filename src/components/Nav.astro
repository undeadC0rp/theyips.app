---
const DOWNLOAD_URL = 'https://github.com/undeadC0rp/theyipsapp-releases/releases/latest';
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-the">the</span>
      <span class="logo-yips">Yips</span>
    </a>
    <a href={DOWNLOAD_URL} class="nav-dl" target="_blank" rel="noopener">
      Download APK
    </a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(26, 26, 26, 0.9);
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    padding-bottom: 16px;
  }

  .nav-logo {
    display: flex;
    align-items: baseline;
    gap: 3px;
    font-weight: 700;
    font-size: 18px;
  }

  .logo-the { color: var(--muted); font-weight: 400; font-size: 14px; }
  .logo-yips { color: var(--text); }

  .nav-dl {
    font-size: 13px;
    font-weight: 600;
    color: var(--bg);
    background: var(--green);
    padding: 8px 16px;
    border-radius: 6px;
    transition: opacity 0.15s;
  }

  .nav-dl:hover { opacity: 0.88; }
</style>
