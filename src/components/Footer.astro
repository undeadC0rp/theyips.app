---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="left">
      <span class="logo-the">the</span>
      <span class="logo-yips">Yips</span>
    </div>
    <p class="center">A <a href="https://undeadcorp.com">undeadCorp</a> product</p>
    <p class="right">© {year} undeadCorp. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 32px 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .left { display: flex; align-items: baseline; gap: 3px; font-weight: 700; }
  .logo-the { color: var(--muted2); font-weight: 400; font-size: 12px; }
  .logo-yips { color: var(--text); font-size: 14px; }

  .center { font-size: 12px; color: var(--muted2); }
  .center a { color: var(--muted); }
  .center a:hover { color: var(--green); }

  .right { font-size: 12px; color: var(--muted2); }
</style>
