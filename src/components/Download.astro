---
const DOWNLOAD_URL = 'https://github.com/undeadC0rp/theyipsapp-releases/releases/latest';
---

<section class="download">
  <div class="container inner">
    <div class="copy">
      <h2>Ready to stop<br /><em>guessing?</em></h2>
      <p>Free download. No account required to get started.</p>
    </div>
    <div class="actions">
      <a href={DOWNLOAD_URL} class="btn-primary" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download APK
      </a>
      <p class="note">
        Android only · Sideload required ·
        <a href="https://www.howtogeek.com/313433/how-to-sideload-apps-on-android/" target="_blank" rel="noopener" class="how-link">How to sideload</a>
      </p>
      <p class="store-note">Google Play Store listing coming soon</p>
    </div>
  </div>
</section>

<style>
  .download {
    padding: 80px 0;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  h2 {
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  h2 em { color: var(--green); font-style: normal; }

  .copy p { font-size: 15px; color: var(--muted); }

  .actions { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--bg);
    background: var(--green);
    padding: 14px 28px;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.88; }

  .note { font-size: 12px; color: var(--muted2); }
  .how-link { color: var(--green); text-decoration: underline; }

  .store-note { font-size: 12px; color: var(--muted2); }
</style>
